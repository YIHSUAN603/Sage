{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sage",
  "version": "0.1.1",
  "identifier": "com.sage.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "avatar",
        "title": "Sage",
        "url": "index.html?window=avatar",
        "width": 208,
        "height": 228,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "acceptFirstMouse": true
      },
      {
        "label": "bubble",
        "title": "Sage Bubble",
        "url": "index.html?window=bubble",
        "width": 300,
        "height": 110,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "focus": false,
        "acceptFirstMouse": true
      },
      {
        "label": "chat",
        "title": "Sage Chat",
        "url": "index.html?window=chat",
        "width": 360,
        "height": 480,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
