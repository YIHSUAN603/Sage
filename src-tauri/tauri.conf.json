{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sage",
  "version": "0.4.2",
  "identifier": "com.sage.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "avatar",
        "title": "Sage",
        "url": "index.html?window=avatar",
        "width": 208,
        "height": 228,
        "minWidth": 120,
        "minHeight": 132,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "acceptFirstMouse": true
      },
      {
        "label": "bubble",
        "title": "Sage Bubble",
        "url": "index.html?window=bubble",
        "width": 300,
        "height": 110,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false,
        "focus": false,
        "acceptFirstMouse": true
      },
      {
        "label": "chat",
        "title": "Sage Chat",
        "url": "index.html?window=chat",
        "width": 360,
        "height": 480,
        "minWidth": 300,
        "minHeight": 380,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "shadow": false,
        "visible": false,
        "acceptFirstMouse": true
      },
      {
        "label": "settings",
        "title": "Sage Settings",
        "url": "index.html?window=settings",
        "width": 640,
        "height": 480,
        "minWidth": 560,
        "minHeight": 400,
        "resizable": true,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxNzk0OURCNTQ2NTdFOUMKUldTY2ZtVlUyMGw1MGI5VUEvNmV3bExnTDkxN2dUTVdhbXJHNks1bGdyNmZEV3JNZ1hsTVBVOGMK",
      "endpoints": [
        "https://github.com/YIHSUAN603/Sage/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
